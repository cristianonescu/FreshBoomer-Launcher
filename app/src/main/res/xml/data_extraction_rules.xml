<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Only back up non-sensitive preferences -->
        <include domain="sharedpref" path="piper_tts_prefs.xml" />

        <!-- Exclude sensitive user data -->
        <exclude domain="sharedpref" path="LauncherPrefs.xml" />
        <exclude domain="sharedpref" path="InactivityTrackerPrefs.xml" />
        <exclude domain="sharedpref" path="MedicationSnoozePrefs.xml" />
        <exclude domain="file" path="config.json" />
        <exclude domain="file" path="quick_contacts.json" />
        <exclude domain="file" path="contact_photos" />

        <!-- Exclude large TTS model binaries -->
        <exclude domain="file" path="piper_models" />
    </cloud-backup>

    <device-transfer>
        <!-- Allow transferring preferences to a new device -->
        <include domain="sharedpref" path="piper_tts_prefs.xml" />

        <!-- Still exclude sensitive data from device-to-device transfer -->
        <exclude domain="sharedpref" path="LauncherPrefs.xml" />
        <exclude domain="sharedpref" path="InactivityTrackerPrefs.xml" />
        <exclude domain="sharedpref" path="MedicationSnoozePrefs.xml" />
        <exclude domain="file" path="config.json" />
        <exclude domain="file" path="quick_contacts.json" />
        <exclude domain="file" path="contact_photos" />

        <!-- Exclude large TTS model binaries -->
        <exclude domain="file" path="piper_models" />
    </device-transfer>
</data-extraction-rules>
